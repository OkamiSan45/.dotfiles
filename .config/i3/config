# このファイルは i3-config-wizard(1) によって自動生成されました。
# 上書きされることはないので、お好きなように編集してください。
#
# 将来的にキーボードレイアウトを変更する場合は、
# このファイルを削除し、i3-config-wizard(1) を再実行してください。
#

# i3 設定ファイル (v4)
#
# 完全なリファレンスについては、http://i3wm.org/docs/userguide.html をご覧ください！

set $mod Mod1

# ウィンドウタイトル用のフォント。異なるフォントが
# 下の bar {} ブロックで使用されない限り、バーにも使用されます。
font pango:DejaVu Sans Mono 5

# ボーダーを取り除く
#
# Childz に感謝
for_window [class="^.*"] border pixel d

# Mouse+$mod で浮動ウィンドウを希望の位置にドラッグします
floating_modifier $mod

# ターミナルを起動
bindsym $mod+Return exec alacritty

# フォーカスされたウィンドウを終了
bindsym $mod+Shift+q kill

# dmenu (プログラムランチャー) を起動
bindsym $mod+d exec --no-startup-id i3-dmenu-desktop

# フォーカスを変更
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# 代わりにカーソルキーを使用できます：
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# フォーカスされたウィンドウを移動
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# 代わりにカーソルキーを使用できます：
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# 水平方向に分割
bindsym $mod+z split h

# 垂直方向に分割
bindsym $mod+v split v

# フォーカスされたコンテナをフルスクリーンモードにする
bindsym $mod+f fullscreen toggle

# コンテナのレイアウトを変更 (スタッキング、タブ、トグル分割)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# タイリング / 浮動を切り替え
bindsym $mod+Shift+space floating toggle

# 親コンテナにフォーカスを移動
bindsym $mod+a focus parent

# ワークスペースに切り替えて壁紙を設定
bindsym $mod+1 workspace 1;
bindsym $mod+2 workspace 2;
bindsym $mod+3 workspace 3;
bindsym $mod+4 workspace 4;
bindsym $mod+5 workspace 5;
bindsym $mod+6 workspace 6;
bindsym $mod+7 workspace 7;
bindsym $mod+8 workspace 8;
bindsym $mod+9 workspace 9;
bindsym $mod+0 workspace 10;

# フォーカスされたコンテナをワークスペースに移動
bindsym $mod+Shift+1 move container to workspace 1
bindsym $mod+Shift+2 move container to workspace 2
bindsym $mod+Shift+3 move container to workspace 3
bindsym $mod+Shift+4 move container to workspace 4
bindsym $mod+Shift+5 move container to workspace 5
bindsym $mod+Shift+6 move container to workspace 6
bindsym $mod+Shift+7 move container to workspace 7
bindsym $mod+Shift+8 move container to workspace 8
bindsym $mod+Shift+9 move container to workspace 9
bindsym $mod+Shift+0 move container to workspace 10

# 設定ファイルを再読み込み
bindsym $mod+Shift+c reload
# i3 を再起動 (レイアウト/セッションを保持し、i3 をアップグレードするために使用可能)
bindsym $mod+Shift+r restart
# i3 を終了 (X セッションからログアウトします)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m '終了ショートカットを押しました。本当に i3 を終了しますか？ これにより X セッションが終了します。' -b 'はい、i3 を終了' 'i3-msg exit'"

# ウィンドウのサイズを変更 (マウスを使っても可能)
mode "resize" {
        # リサイズモードに入るとすぐにこのバインディングがトリガーされます

        # 左を押すとウィンドウの幅が小さくなります。
        # 右を押すとウィンドウの幅が大きくなります。
        # 上を押すとウィンドウの高さが小さくなります。
        # 下を押すとウィンドウの高さが大きくなります。
        bindsym h resize shrink width 2 px or 10 ppt
        bindsym j resize grow height 2 px or 10 ppt
        bindsym k resize shrink height 2 px or 10 ppt
        bindsym l resize grow width 2 px or 10 ppt

        # 同じバインディングですが、矢印キー用
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # 通常モードに戻る：Enter または Escape
        bindsym Return mode "default"
        bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"

# i3bar を起動してワークスペースバーを表示 (利用可能な場合、システム情報を i3status が取得)
bar {
        status_command i3status
        tray_output primary
}

# ------------------------------------------
# カスタムキーの開始
# ------------------------------------------
exec ~/bin/set_random_wallpaper.sh
exec --no-startup-id nm-applet
exec --no-startup-id autotiling
exec --no-startup-id picom --config ~/.config/picom/picom.conf
bindsym $mod+Shift+s exec --no-startup-id ~/dotfiles/bin/monitor
bindsym $mod+Shift+n exec --no-startup-id ~/dotfiles/bin/resolution

# ファンクションキー
# Pulse Audio コントロール
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume 0 +5% # 音量を上げる
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume 0 -5% # 音量を下げる
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute 0 toggle # 音をミュート

# スクリーンの明るさコントロール
# brightnessctl でスクリーンの明るさを調整
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# ALSA オーディオコントロール
bindsym $mod+Shift+comma exec ~/.config/i3/scripts/alsa restore
bindsym $mod+semicolon exec ~/.config/i3/scripts/alsa down Headphone
bindsym $mod+comma exec ~/.config/i3/scripts/alsa up Headphone
bindsym $mod+m move workspace to output left

# サスペンド
bindsym $mod+Ctrl+r exec ~/bin/set_random_wallpaper.sh
bindsym $mod+Shift+period exec systemctl suspend
